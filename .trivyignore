# .trivyignore — CVEs acknowledged as not-exploitable in this container.
# Generated 2026-04-28. Re-evaluate on every image rebuild.
#
# Format:  CVE-ID  # rationale (one line)
#
# RUNTIME HARDENING applied (still in place even when these CVEs would otherwise apply):
#   --cap-drop ALL  --read-only  --no-new-privileges
#   --pids-limit 200  --memory 256m  --cpus 1.0
#   nofile=4096  nproc=200  core=0
#   AppArmor=docker-default  ipc=private  user=nonroot(65532)
#   ALLOWED_METHODS=GET,HEAD,POST,OPTIONS  UPSTREAM_MAX_BODY=2MiB  UPSTREAM_MAX_RESP=8MiB

# ── libpython3.13-* family (xmlrpc/ssl/urllib edge-case stdlib bugs) ───────
# proxy.py uses only aiohttp / sqlite3 / ssl / asyncio / json / hashlib. None
# of the affected stdlib modules (xml, pickle, marshal, ftplib, …) are loaded.
