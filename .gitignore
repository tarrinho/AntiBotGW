# ── Local-only files (never pushed to GitHub) ───────────────────────────

# git internals (defensive — git auto-excludes anyway)
.git/
.git*
!.gitignore
!.github/
# `.git*` above also swallows .gitleaks.toml — it MUST be committed: the
# secret-scan workflow auto-loads it from the repo root, and without it gitleaks
# runs stock rules and reports the known false positives on every run.
!.gitleaks.toml

# Helper scripts and local secrets — never committed
copy-to-github.sh
publish.sh
tag-versions.sh
.env
# Internal release-pipeline doc: carries live hostnames, admin-key reads and
# local paths. It is in copy-to-github.sh _BLOCKLIST so it is never *copied* —
# but the copy is overwrite-in-place, so a stale rules.md left in a destination
# repo would still be swept up by `git add -A`. Ignore it there too.
rules.md

# GeoLite2 DBs — size + MaxMind licensing; provided at runtime, never committed
_seed/

# ── Runtime state (live container DB + secrets) ─────────────────────────
antibot.db
antibot.db-shm
antibot.db-wal
gw.db
gw.db-shm
gw.db-wal
gw.sqlite
.admin_key
.session_key
.pow_key
.admin_key.stale-*
.session_key.stale-*
mutants/.admin_key
mutants/.session_key
mutants/.pow_key

# ── Python cruft ────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.mutmut-cache
.mypy_cache/
.ruff_cache/
*.egg-info/
.coverage
htmlcov/

# ── Non-published local/dev artifacts (never sent to repos) ───────────────
attack_demo.py
demo-attack-traffic.py
fix_theme_*.py
analysis.result.md
GW-Tests-Full.md
*.db
*.sqlite
*.sqlite3
sbom/*.json
report.html
report.pdf
report-*.html
manual/*report*
manual/*.pdf

# ── OS / editor ─────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*~

# ── Local build outputs ─────────────────────────────────────────────────
*.tar
*.tgz
dist/
build/

# ── Build/test logs, backups, runtime dirs, generated trees (never committed) ──
*.log
.claude/
Users/
*.orig
mutants/
*.mmdb
data/
gwdata/
